# Misskey設定
MISSKEY_HOST=your-misskey-instance.example.com
MISSKEY_API_TOKEN=your_misskey_api_token

# Slack設定
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Notion設定
NOTION_API_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# 収集設定（任意）
# タスクとして収集する投稿のハッシュタグ（カンマ区切り、省略時はすべての投稿を対象）
TASK_HASHTAGS=#やりたいこと,#todo,#タスク
# 収集対象の時間範囲（時間単位、デフォルト: 25時間 = 確実に昨日分をカバー）
COLLECT_HOURS=25
