# Misskey設定
MISSKEY_HOST=your-misskey-instance.example.com
MISSKEY_API_TOKEN=your_misskey_api_token

# Slack設定
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_WORKSPACE_DOMAIN=your-workspace

# Claude API（タスク判定・カテゴリ分類に使用）
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Obsidian設定
# iCloudの場合の例:
# OBSIDIAN_VAULT_PATH=/Users/yourname/Library/Mobile Documents/iCloud~md~obsidian/Documents/MyVault
# Dropboxの場合の例:
# OBSIDIAN_VAULT_PATH=/Users/yourname/Dropbox/ObsidianVault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
OBSIDIAN_TASKS_FILE=Tasks.md

# 収集設定（任意）
# 収集対象の時間範囲（時間単位、デフォルト: 25時間 = 確実に昨日分をカバー）
COLLECT_HOURS=25
